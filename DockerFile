1.	from collections import deque
print("1.Missionaries and cannibals problem using BFS Algorithm.")
print("Name: Kirti Tripathi")
print("Register Number: 23MIS0043")

def safe(state):
    Lm, Lc, Rm, Rc, boat_side = state
    if min(Lm, Lc, Rm, Rc) < 0:
        return False

    if (Lm != 0 and Lc > Lm) or (Rm != 0 and Rc > Rm):
        return False

    return True

def bfs_mc():
    start_state = (3, 3, 0, 0, 0)
    end_state = (0, 0, 3, 3, 1)

    q = deque()
    q.append((start_state, []))
    explored = set()

    transitions = [(1,0), (0,1), (2,0), (0,2), (1,1)]

    while q:
        current, history = q.popleft()

        if current == end_state:
            return history + [current]

        if current in explored:
            continue

        explored.add(current)

        Lm, Lc, Rm, Rc, boat_side = current

        for m, c in transitions:
            if boat_side == 0:
                nxt = (Lm-m, Lc-c, Rm+m, Rc+c, 1)
            else:
                nxt = (Lm+m, Lc+c, Rm-m, Rc-c, 0)

            if safe(nxt):
                q.append((nxt, history + [current]))
path = bfs_mc()

print("Solution Path:")
for p in path:
    print(p)
2.	from collections import deque

print("2. Water Jug Problem using BFS Algorithm ")
print("Name:Kirti Tripathi ")
print("Register Number: 23MIS0043")

def water_jug_bfs():
    J1, J2 = 4, 3
    target = 2

    q = deque([((0, 0), [])])
    seen = set()

    while q:
        (x, y), trace = q.popleft()

        if x == target or y == target:
            return trace + [(x, y)]

        if (x, y) in seen:
            continue

        seen.add((x, y))

        possibilities = [
            (J1, y),
            (x, J2),
            (0, y),
            (x, 0),
            (x - min(x, J2 - y), y + min(x, J2 - y)),
            (x + min(y, J1 - x), y - min(y, J1 - x))
        ]

        for nxt in possibilities:
            if nxt not in seen:
                q.append((nxt, trace + [(x, y)]))

answer = water_jug_bfs()

print("Solution Path:")
for step in answer:
    print(step)


3.	print("3. Missionaries and cannibals problem using DFS Algorithm")
print("Name: Kirti Tripathi")
print("Register Number: 23MIS0043")

def valid_move(state):
    a, b, c, d, side = state

    if a < 0 or b < 0 or c < 0 or d < 0:
        return False

    if (a != 0 and b > a) or (c != 0 and d > c):
        return False

    return True

def dfs_mc(current, destination, visited, result):
    if current == destination:
        return result + [current]

    visited.add(current)

    a, b, c, d, side = current
    actions = [(1,0), (0,1), (2,0), (0,2), (1,1)]

    for m, n in actions:
        if side == 0:
            next_step = (a-m, b-n, c+m, d+n, 1)
        else:
            next_step = (a+m, b+n, c-m, d-n, 0)

        if valid_move(next_step) and next_step not in visited:
            sol = dfs_mc(next_step, destination, visited, result + [current])
            if sol:
                return sol

    return None

start = (3, 3, 0, 0, 0)
end = (0, 0, 3, 3, 1)

final_path = dfs_mc(start, end, set(), [])

print("Solution Path:")
for s in final_path:
    print(s)


4.	import itertools

def chk(m,w1,w2,res):
    def to_num(w): return int("".join(str(m[ch]) for ch in w))
    return to_num(w1)+to_num(w2)==to_num(res)

def solve(w1,w2,res):
    l=set(w1+w2+res)
    if len(l)>10: return None
    l=list(l)
    for p in itertools.permutations(range(10),len(l)):
        m=dict(zip(l,p))
        if m[w1[0]]==0 or m[w2[0]]==0 or m[res[0]]==0: continue
        if chk(m,w1,w2,res): return m
    return None

if __name__=="__main__":
    w1,w2,res="SEND","MORE","MONEY"
    s=solve(w1,w2,res)
    print("Name: KIRTI TRIPATHI")
    print("Register Number: 23MIS0043")
    print(f"{w1}+{w2}={res}")
    if s: 
        for k,v in s.items(): print(k,"=",v)
    else: print("No solution")


5.	print("Cryptarithmetic Problem using CSP with Backtracking")
print("Name: Kirti Tripathi")
print("Register Number: 23MIS0043")
print("Cryptarithmetic Problem: SEND + MORE = MONEY\n")

letters = ['S','E','N','D','M','O','R','Y']
digits = range(10)

def solve(assignments, used_digits):
    
    if len(assignments) == len(letters):

        S = assignments['S']
        E = assignments['E']
        N = assignments['N']
        D = assignments['D']
        M = assignments['M']
        O = assignments['O']
        R = assignments['R']
        Y = assignments['Y']

        send = S*1000 + E*100 + N*10 + D
        more = M*1000 + O*100 + R*10 + E
        money = M*10000 + O*1000 + N*100 + E*10 + Y

        if send + more == money:
            print("Solution Found:\n")
            print("S =", S)
            print("E =", E)
            print("N =", N)
            print("D =", D)
            print("M =", M)
            print("O =", O)
            print("R =", R)
            print("Y =", Y)
            print("\nSEND =", send)
            print("MORE =", more)
            print("MONEY =", money)
            return True

        return False
    
    var = letters[len(assignments)]
    
    for digit in digits:
        
        if digit in used_digits:
            continue
        
        if var in ['S','M'] and digit == 0:
            continue

        assignments[var] = digit
        used_digits.add(digit)
        
        if solve(assignments, used_digits):
            return True
        
        del assignments[var]
        used_digits.remove(digit)

    return False

solve({}, set())


