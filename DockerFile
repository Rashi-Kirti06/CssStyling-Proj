# Depth Limited Search

def dls(graph, node, goal, depth, visited):
    if depth < 0:
        return False
    
    print("Visiting:", node)
    
    if node == goal:
        return True
    
    visited.add(node)
    
    for neighbor in graph[node]:
        if neighbor not in visited:
            if dls(graph, neighbor, goal, depth - 1, visited):
                return True
    
    return False


# Graph representation
graph = {
    'A': ['B', 'C'],
    'B': ['D', 'E'],
    'C': ['F'],
    'D': [],
    'E': [],
    'F': []
}

start = 'A'
goal = 'E'
depth_limit = 2

visited = set()

if dls(graph, start, goal, depth_limit, visited):
    print("Goal Found")
else:
    print("Goal Not Found")


