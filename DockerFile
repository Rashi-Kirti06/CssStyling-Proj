12.	def dfs_search(graph, node, target, visited):
    if node == target:
        return True
    
    visited.add(node)
    
    for neighbor in graph[node]:
        if neighbor not in visited:
            if dfs_search(graph, neighbor, target, visited):
                return True
    return False

# Usage
visited = set()
print(dfs_search(graph, 'A', 'F', visited))  # True or False


